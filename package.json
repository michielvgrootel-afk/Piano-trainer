{
  "name": "piano-trainer",
  "version": "1.1.0",
  "description": "Guitar Hero for Piano — MIDI keyboard trainer with falling notes",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite build && electron ."
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "dexie": "^4.0.11",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "electron": "^34.1.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.pianotrainer.app",
    "productName": "Piano Trainer",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "michielvgrootel-afk",
      "repo": "Piano-trainer"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
